# El Papu Store — Variables de entorno
# =====================================================================
# Copiar este archivo a `.env` y completar los valores.
# NUNCA commitear `.env` real (ya está en .gitignore).
# =====================================================================

# ─── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://tudominio.com

# ─── Supabase ─────────────────────────────────────────────────────────
# Las dos primeras también están en index.html (públicas por diseño)
SUPABASE_URL=https://api.neura.com.py
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PRIVADA: solo backend. Dashboard Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_SCHEMA=elpapustore

# ─── PagoPar ──────────────────────────────────────────────────────────
PAGOPAR_TOKEN_PUBLICO=
PAGOPAR_TOKEN=
PAGOPAR_BASE_URL=https://api.pagopar.com/api
PAGOPAR_MODE=production

# URLs adonde PagoPar redirige al usuario tras el pago
PAGOPAR_URL_RETORNO_OK=https://tudominio.com/checkout/success
PAGOPAR_URL_RETORNO_PENDIENTE=https://tudominio.com/checkout/pendiente
PAGOPAR_URL_RETORNO_FALLO=https://tudominio.com/checkout/error

# URL a la que PagoPar manda el webhook server-to-server
PAGOPAR_WEBHOOK_URL=https://tudominio.com/api/pagopar/webhook

# Secreto compartido para validar el webhook (generá con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" )
PAGOPAR_WEBHOOK_SECRET=

# ─── Seguridad ────────────────────────────────────────────────────────
CORS_ORIGIN=https://tudominio.com
SESSION_SECRET=

# ─── Opcional ─────────────────────────────────────────────────────────
LOG_LEVEL=info
